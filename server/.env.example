# Copy to .env and fill in. .env is gitignored.

PORT=4000

# FastAPI service serving the PyTorch model (frame-level predictions as JSON).
# Leave unset to use the built-in mock analyzer.
ML_SERVICE_URL=

# RAG pipeline / LLM. Leave unset to use the mock explanation generator.
ANTHROPIC_API_KEY=

# Where uploaded clips are stored. "local" writes to server/uploads/.
# Swap for S3 later (bucket name below).
STORAGE_DRIVER=local
S3_BUCKET=
